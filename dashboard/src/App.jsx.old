  const getWeekDates = () => {
    const start = new Date(currentWeek);
    start.setDate(start.getDate() - start.getDay());
    
    const dates = [];
    for (let i = 0; i < 7; i++) {
      const date = new Date(start);
      date.setDate(date.getDate() + i);
      dates.push(date);
    }
    return dates;
  };

  const weekDates = getWeekDates();
  const weekStart = weekDates[0];
  const weekEnd = weekDates[6];

  const formatDate = (date) => {
    return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
  };

  const getDayName = (date) => {
    return date.toLocaleDateString('en-US', { weekday: 'long' });
  };

  const getDayNumber = (date) => {
    return date.getDate();
  };

  const isSameDay = (date1, date2) => {
    // console.log(typeof(date2));
    return date1.getFullYear() === date2.getFullYear() &&
           date1.getMonth() === date2.getMonth() &&
           date1.getDate() === date2.getDate();
  };

  const getOrdersForTechAndDay = (techId, date) => {
    // console.log(orders.forEach((order) => console.log(order.status)));
    return orders.filter(order => {
      order = order.data;
      // console.log(order);
      if (order.technician_id !== techId) return false;
      // if (!order.start_time) return false;
      // console.log(order);
      const lastDate = order.completion_time ?? order.start_time ?? order.updated_at;
      
      // console.log(date);
      // if (order.completion_time != null) orderDate = new Date(order.completion_time);
      // else if (orderDate.start_time != null) orderDate = new Date(order.start_time);
      // else orderDate = new Date(order.updated_at);
      const orderDate = new Date(lastDate);
      return isSameDay(orderDate, date);
    });
  };

  const getStatusColor = (status) => {
    const colors = {
      "pending": 'bg-orange-600',
      "in_progress": 'bg-blue-500',
      "completed": 'bg-green-600',
      'cancelled': 'bg-red-600'
    };
    return colors[status] || 'bg-gray-200';
  };

  const getInitials = (name) => {
    return name.split(' ').map(n => n[0]).join('').toUpperCase();
  };

  const navigateWeek = (direction) => {
    const newDate = new Date(currentWeek);
    newDate.setDate(newDate.getDate() + (direction * 7));
    setCurrentWeek(newDate);
  };

  const handleCreateOrder = async () => {
    // console.log(newOrder);
    if (!newOrder.customer_name || !newOrder.technician_id || !newOrder.start_time) {
      alert('Please fill in all required fields');
      return;
    }

    let maxNumber = 0;

  orders.forEach(order => {
    // const num = parseInt(order.data._id.replace("wo_", ""), 10);
    if (!isNaN(num) && num > maxNumber) {
      maxNumber = num;
    }
  });

  const nextNumber = String(maxNumber + 1).padStart(3, "0");

    const orderData = {
      _id: `wo_${nextNumber}`,
      customer_name: newOrder.customer_name,
      customer_address: newOrder.customer_address,
      equipment_model: newOrder.equipment_model,
      equipment_serial: newOrder.equipment_serial,
      problem_description: newOrder.problem_description,
      technician_id: newOrder.technician_id,
      start_time: newOrder.start_time,
      status: newOrder.status,
      created_at: new Date().toISOString(),
      updated_at: new Date().toISOString()
    };

    // console.log(orderData);

    try {
      // console.log(orderData);
      const response = await fetch(`${API_BASE_URL}/workorders/`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify(orderData)
      });

      console.log(await response.json());

      const createdOrder = await response.json();
      setOrders([...orders, createdOrder]);
      setShowNewOrderModal(false);
      setNewOrder({
        customer_name: '',
        customer_address: '',
        equipment_model: '',
        equipment_serial: '',
        problem_description: '',
        technician_id: '',
        start_time: '',
        status: 'scheduled'
      });
    } catch (error) {
      console.error('Error creating order:', error);
      // Fallback: add order locally
      const order = {
        id: String(orders.length + 1),
        ...orderData
      };
      setOrders([...orders, order]);
      setShowNewOrderModal(false);
      setNewOrder({
        customer_name: '',
        customer_address: '',
        equipment_model: '',
        equipment_serial: '',
        problem_description: '',
        technician_id: '',
        start_time: '',
        status: 'scheduled'
      });
    }
  };

  const handleDeleteOrder = async (orderId) => {
    try {
      await fetch(`${API_BASE_URL}/workorders/${orderId}/`, {
        method: 'DELETE'
      });
      setOrders(orders.filter(o => o.id !== orderId));
      setSelectedOrder(null);
    } catch (error) {
      console.error('Error deleting order:', error);
      // Fallback: delete locally
      setOrders(orders.filter(o => o.id !== orderId));
      setSelectedOrder(null);
    }
  };

  const handleUpdateOrderStatus = async (orderId, newStatus) => {
    try {
      await fetch(`${API_BASE_URL}/workorders/${orderId}`, {
        method: 'PUT',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          status: newStatus,
          updated_at: new Date().toISOString(),
          ...(newStatus === 'completed' ? { completion_time: new Date().toISOString() } : {})
        })
      });
      
      setOrders(orders.map(o => 
        o.id === orderId 
          ? { ...o, status: newStatus, updated_at: new Date().toISOString(), ...(newStatus === 'completed' ? { completion_time: new Date().toISOString() } : {}) }
          : o
      ));
      
      if (selectedOrder && selectedOrder.id === orderId) {
        setSelectedOrder({ ...selectedOrder, status: newStatus });
      }
    } catch (error) {
      console.error('Error updating order:', error);
      // Fallback: update locally
      setOrders(orders.map(o => 
        o.id === orderId 
          ? { ...o, status: newStatus, updated_at: new Date().toISOString() }
          : o
      ));
      if (selectedOrder && selectedOrder.id === orderId) {
        setSelectedOrder({ ...selectedOrder, status: newStatus });
      }
    }
  };

  const filteredTechnicians = technicians.filter(tech =>
