                  className="flex-1 bg-purple-600 text-white px-4 py-2 rounded hover:bg-purple-700"
                >
                  Create Order
                </button>
                <button
                  onClick={() => setShowNewOrderModal(false)}
                  className="flex-1 bg-gray-200 text-gray-700 px-4 py-2 rounded hover:bg-gray-300"
                >
                  Cancel
                </button>
              </div>
            </div>
          </div>
        </div>
      )}

      {/* Order Detail Sidebar */}
      {selectedOrder && (
        <div className="fixed right-0 top-0 h-full w-96 bg-white shadow-xl border-l border-gray-200 p-6 z-20 overflow-y-auto">
          <div className="flex justify-between items-start mb-4">
            <h3 className="font-semibold text-lg">Order Details</h3>
            <button onClick={() => setSelectedOrder(null)} className="text-gray-400 hover:text-gray-600">
              <X className="w-5 h-5" />
            </button>
          </div>
          <div className="space-y-4 text-sm">
            <div>
              <span className="text-gray-600 font-medium">Customer:</span>
              <div className="mt-1">{selectedOrder.customer_name}</div>
            </div>
            <div>
              <span className="text-gray-600 font-medium">Address:</span>
              <div className="mt-1">{selectedOrder.customer_address}</div>
            </div>
            <div className="grid grid-cols-2 gap-4">
              <div>
                <span className="text-gray-600 font-medium">Equipment:</span>
                <div className="mt-1">{selectedOrder.equipment_model}</div>
              </div>
              <div>
                <span className="text-gray-600 font-medium">Serial:</span>
                <div className="mt-1">{selectedOrder.equipment_serial}</div>
              </div>
            </div>
            <div>
              <span className="text-gray-600 font-medium">Problem:</span>
              <div className="mt-1">{selectedOrder.problem_description}</div>
            </div>
            <div>
              <span className="text-gray-600 font-medium">Technician:</span>
              <div className="mt-1">{technicians.find(t => t.id === selectedOrder.technician_id)?.name}</div>
            </div>
            <div>
              <span className="text-gray-600 font-medium">Start Time:</span>
              <div className="mt-1">{selectedOrder.start_time ? new Date(selectedOrder.start_time).toLocaleString() : 'Not set'}</div>
            </div>
            <div>
              <span className="text-gray-600 font-medium">Status:</span>
              <div className="mt-2">
                <select
                  value={selectedOrder.status}
                  onChange={(e) => handleUpdateOrderStatus(selectedOrder.id, e.target.value)}
                  className="w-full px-3 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-purple-600"
                >
                  <option value="scheduled">Scheduled</option>
                  <option value="in_progress">In Progress</option>
                  <option value="completed">Completed</option>
                  <option value="on_call">On Call</option>
                  <option value="cancelled">Cancelled</option>
                </select>
              </div>
            </div>
            {selectedOrder.completion_time && (
              <div>
                <span className="text-gray-600 font-medium">Completed:</span>
                <div className="mt-1">{new Date(selectedOrder.completion_time).toLocaleString()}</div>
              </div>
            )}
            <button
              onClick={() => handleDeleteOrder(selectedOrder.id)}
              className="w-full mt-6 bg-red-500 text-white px-4 py-2 rounded hover:bg-red-600"
            >
              Delete Order
            </button>
          </div>
        </div>
      )}
    </div>
  );
};

export default FieldServiceDashboard;