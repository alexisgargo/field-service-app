      </div>

      {/* Week Navigation */}
      <div className="bg-white border-b border-gray-200 px-6 py-4 flex items-center gap-4">
        <button className="px-4 py-2 text-sm border border-gray-300 rounded hover:bg-gray-50 text-white">
          Today
        </button>
        <div className="flex items-center gap-2">
          <button 
