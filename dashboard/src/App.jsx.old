      {/* Calendar Grid */}
      <div className="flex-1 overflow-auto">
        <div className="min-w-full bg-white">
          {/* Header Row */}
          <div className="grid grid-cols-8 bg-white border-b border-gray-200 sticky top-0 z-10">
