      // if (document != null) {
      //   await _ditto!.store.collection('work_orders').findByID(id).remove();
      // }

      // Simulated local storage deletion (until actual Ditto SDK is integrated)
      final removedData = _localData.remove(id);
      
      if (removedData != null) {
        // Queue for sync if we have connectivity issues or are offline
        if (!_hasNetworkConnectivity || !_isConnected) {
          _queueSyncOperation('delete', id, null);
        }
        
        _notifyWorkOrdersChanged();
        print(
          'DittoService: Deleted work order $id (SIMULATION MODE) (offline: ${!_hasNetworkConnectivity})',
        );
      } else {
        throw OfflineOperationException(
          'Work order with ID $id not found locally',
        );
      }
    } catch (e) {
      print('DittoService: Failed to delete work order - $e');
      if (e is OfflineOperationException) rethrow;
      throw OfflineOperationException('Failed to delete work order with Ditto SDK', e);
    }
  }

