  /// Subscribe to real-time work order changes (works offline)
  Stream<List<WorkOrder>> subscribeToWorkOrders() {
    if (!_isInitialized) {
      throw OfflineOperationException(
        'DittoService must be initialized before subscribing to data',
      );
    }

    // Use actual Ditto SDK subscription for real-time updates
    // _workOrdersSubscription = _ditto!.store.collection('work_orders').findAll().observe((docs, event) {
    //   final workOrders = docs.map((doc) => WorkOrder.fromJson(doc.value)).toList();
    //   workOrders.sort((a, b) => b.createdAt.compareTo(a.createdAt));
    //   _workOrdersController.add(workOrders);
    // });

    return _workOrdersController.stream;

    // COMMENTED OUT: Simulated subscription
    // return _workOrdersController.stream;
  }

  /// Subscribe to changes for a specific work order (works offline)
  Stream<WorkOrder?> subscribeToWorkOrder(String id) {
    if (!_isInitialized) {
      throw OfflineOperationException(
        'DittoService must be initialized before subscribing to data',
      );
    }

    return _workOrdersController.stream.map((workOrders) {
      try {
        return workOrders.firstWhere((wo) => wo.id == id);
      } catch (e) {
        return null;
      }
    });
  }

  /// Subscribe to work orders by status with real-time updates (works offline)
  Stream<List<WorkOrder>> subscribeToWorkOrdersByStatus(
    WorkOrderStatus status,
  ) {
    if (!_isInitialized) {
      throw OfflineOperationException(
        'DittoService must be initialized before subscribing to data',
      );
    }

    return _workOrdersController.stream.map((workOrders) {
      return workOrders.where((wo) => wo.status == status).toList();
    });
  }

  /// Subscribe to work orders by technician with real-time updates (works offline)
  Stream<List<WorkOrder>> subscribeToWorkOrdersByTechnician(
    String technicianId,
  ) {
    if (!_isInitialized) {
      throw OfflineOperationException(
        'DittoService must be initialized before subscribing to data',
      );
    }

    return _workOrdersController.stream.map((workOrders) {
      return workOrders.where((wo) => wo.technicianId == technicianId).toList();
    });
  }

  /// Get connection statistics and sync information
  Map<String, dynamic> getConnectionInfo() {
    return {
      'isInitialized': _isInitialized,
      'isConnected': _isConnected,
      'hasNetworkConnectivity': _hasNetworkConnectivity,
      'isOffline': isOffline,
      'syncStatus': _hasNetworkConnectivity && _isConnected
          ? 'connected'
          : 'offline',
      'lastSyncTime': DateTime.now().toIso8601String(),
      'totalWorkOrders': _localData.length, // Simulation data count
      'pendingSyncOperations': _pendingSyncOperations.length, // Simulation pending operations
      'mode': 'SIMULATION', // Indicates current mode
    };
  }

  /// Force a manual sync operation
  Future<void> forceSync() async {
    if (!_isInitialized) {
      throw OfflineOperationException(
        'DittoService must be initialized before forcing sync',
      );
    }

    try {
      // Check network connectivity first
      await _checkNetworkConnectivity();

      if (!_hasNetworkConnectivity) {
        throw NetworkOperationException(
          'Cannot sync: No network connectivity available',
        );
      }

      _syncStatusController.add(SyncStatus.syncing);

      // COMMENTED OUT: Process any pending sync operations
      // await _processPendingSyncOperations();

      // COMMENTED OUT: Simulate additional sync operation
      // await Future.delayed(const Duration(seconds: 1));

      // With Ditto SDK, sync is automatic, so just update status
      if (_isConnected && _hasNetworkConnectivity) {
        _syncStatusController.add(SyncStatus.synced);
      } else {
        _syncStatusController.add(SyncStatus.offline);
      }

      print(
        'DittoService: Manual sync completed using Ditto SDK',
      );
    } catch (e) {
      print('DittoService: Failed to force sync - $e');
      _syncStatusController.add(SyncStatus.error);
      if (e is NetworkOperationException || e is OfflineOperationException) {
        rethrow;
      }
      throw NetworkOperationException('Failed to complete manual sync', e);
    }
  }

  /// Notify subscribers of work order changes (simulation until actual Ditto SDK subscriptions)
  void _notifyWorkOrdersChanged() {
    // TODO: With actual Ditto SDK, real-time updates are handled by the observe() subscription
    // No manual notification needed
    
    // Simulated notification (until actual Ditto SDK is integrated)
    final workOrders = _localData.values
        .map((json) => WorkOrder.fromJson(json))
        .toList();
    workOrders.sort((a, b) => b.createdAt.compareTo(a.createdAt));
    _workOrdersController.add(workOrders);
  }

  /// Dispose resources
  void dispose() {
    _connectionTimer?.cancel();
    _networkCheckTimer?.cancel();
    
    // Clean up Ditto subscription
    // _workOrdersSubscription?.cancel();
    
    _connectionStatusController.close();
    _syncStatusController.close();
    _workOrdersController.close();
  }
}
